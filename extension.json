{
	"name": "Mustache",
	"version": "1.0.0",
	"author": "lihaohong6",
	"url": "https://www.mediawiki.org/wiki/Extension:Mustache",
	"descriptionmsg": "mustache-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "parserhook",
	"requires": {
		"MediaWiki": ">= 1.45.0"
	},
	"namespaces": [
		{
			"id": 9200,
			"constant": "NS_MUSTACHE",
			"name": "Mustache",
			"defaultcontentmodel": "mustache",
			"subpages": false,
			"protection": ["editsitecss", "editsitejs"]
		},
		{
			"id": 9201,
			"constant": "NS_MUSTACHE_TALK",
			"name": "Mustache_talk",
			"subpages": false
		},
		{
			"id": 9210,
			"constant": "NS_HTML",
			"name": "Html",
			"defaultcontentmodel": "html",
			"subpages": false,
			"protection": ["editsitecss", "editsitejs"]
		},
		{
			"id": 9211,
			"constant": "NS_HTML_TALK",
			"name": "Html_talk",
			"subpages": false
		}
	],
	"attributes": {
		"TemplateSandbox": {
			"EditNamespaces": [
				9200,
				9210
			]
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Mustache\\ContentModels\\": "includes/ContentModels/",
		"MediaWiki\\Extension\\Mustache\\": "includes/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\Mustache\\Tests\\": "tests/phpunit/"
	},
	"config": {
		"MustacheCacheType": {
			"value": "none",
			"description": "Cache backend for compiled Mustache templates. Values: 'none' (disable caching), 'filesystem' (write PHP files to wgMustacheCacheDir), 'mediawiki' (use MediaWiki's configured object cache via BagOStuff)."
		},
		"MustacheCacheDir": {
			"value": "",
			"description": "Directory path for compiled Mustache template cache. Only used when MustacheCacheType is 'filesystem'."
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"callback": "MediaWiki\\Extension\\Mustache\\MustacheHooks::onRegistration",
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\Mustache\\MustacheHooks",
			"services": ["Mustache.Renderer"]
		},
		"codeeditor": {
			"class": "MediaWiki\\Extension\\Mustache\\MustacheCodeEditorHooks"
		}
	},
	"Hooks": {
		"ParserFirstCallInit": "main",
		"ScribuntoExternalLibraries": "main",
		"ParserAfterTidy": "main",
		"CodeEditorGetPageLanguage": "codeeditor"
	},
	"MessagesDirs": {
		"Mustache": "i18n"
	},
	"ExtensionMessagesFiles": {
		"MustacheMagic": "Mustache.i18n.php"
	},
	"ContentHandlers": {
		"mustache": {
			"class": "MediaWiki\\Extension\\Mustache\\ContentModels\\MustacheContentHandler"
		},
		"html": {
			"class": "MediaWiki\\Extension\\Mustache\\ContentModels\\HtmlContentHandler"
		}
	},
	"ParsoidModules": [
		"MediaWiki\\Extension\\Mustache\\Parsoid\\MustacheParsoidModule"
	],
	"manifest_version": 2
}
